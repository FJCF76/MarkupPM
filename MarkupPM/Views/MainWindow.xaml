<Window x:Class="MarkupPM.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:dd="urn:gong-wpf-dragdrop"
        xmlns:converters="clr-namespace:MarkupPM.Converters"
        xmlns:vm="clr-namespace:MarkupPM.ViewModels"
        xmlns:views="clr-namespace:MarkupPM.Views"
        xmlns:models="clr-namespace:MarkupPM.Models"
        Title="{Binding TituloVentana}"
        MinWidth="800" MinHeight="600"
        Width="1200" Height="750"
        Icon="/Assets/app.ico"
        WindowStartupLocation="CenterScreen"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        TextElement.FontFamily="{materialDesign:MaterialDesignFont}"
        FontSize="13">
    <Window.Resources>
        <converters:EstadoToColorConverter x:Key="EstadoColor"/>
        <converters:PrioridadToColorConverter x:Key="PrioridadColor"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:BoolToVisibilityConverter x:Key="InvBoolToVis" Invert="True"/>
        <converters:NullToVisibilityConverter x:Key="NullToVis" Invert="True"/>
        <converters:NullToVisibilityConverter x:Key="NotNullToVis"/>
        <SolidColorBrush x:Key="ActionAccentBrush" Color="#FF7E57C2"/>
        <Style x:Key="ToolbarActionButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedLightButton}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#CCFFFFFF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45"/>
                    <Setter Property="BorderBrush" Value="#55FFFFFF"/>
                    <Setter Property="Foreground" Value="#88FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding GuardarCommand}"/>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding AbrirDialogoCommand}"/>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding NuevoProyectoCommand}"/>
        <KeyBinding Key="Escape" Command="{Binding ClosePanelCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══════════════════════ TOOLBAR ══════════════════════ -->
        <materialDesign:ColorZone Grid.Row="0" Mode="PrimaryMid" Padding="12,6">
            <DockPanel>
                <!-- App logo + name -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" Margin="0,0,16,0">
                    <Border Width="26" Height="26" Background="{DynamicResource PrimaryHueMidBrush}" CornerRadius="4"
                            Margin="0,0,8,0">
                        <TextBlock Text="MP" FontSize="11" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="MarkupPM" FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center" Foreground="White"/>
                </StackPanel>

                <!-- Toolbar buttons -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <Button Style="{StaticResource ToolbarActionButton}"
                            Command="{Binding NuevoProyectoCommand}"
                            Margin="0,0,6,0" Height="32" Padding="10,4"
                            ToolTip="Nuevo proyecto (Ctrl+N)">
                        + Nuevo
                    </Button>
                    <Button Style="{StaticResource ToolbarActionButton}"
                            Command="{Binding AbrirDialogoCommand}"
                            Margin="0,0,6,0" Height="32" Padding="10,4"
                            ToolTip="Abrir archivo (Ctrl+O)">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FolderOpenOutline" Width="16" Height="16"
                                                      VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="Abrir" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Separator Style="{StaticResource MaterialDesignLightSeparator}"
                               Width="1" Margin="4,4"/>
                    <Button Style="{StaticResource ToolbarActionButton}"
                            Command="{Binding GuardarCommand}"
                            Height="32" Padding="10,4"
                            ToolTip="Guardar (Ctrl+S)">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ContentSaveOutline" Width="16" Height="16"
                                                      VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="Guardar" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Right side: filename + theme toggle -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center" Margin="12,0,0,0">
                    <!-- File name with unsaved indicator -->
                    <Border VerticalAlignment="Center"
                            Margin="0,0,16,0"
                            Padding="10,4"
                            CornerRadius="12"
                            BorderThickness="1"
                            BorderBrush="#52FFFFFF"
                            Background="#1FFFFFFF">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Style="{StaticResource UnsavedDot}"
                                     Visibility="{Binding IsDirty, Converter={StaticResource BoolToVis}}"
                                     Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding FileNameDisplay}" FontSize="12"
                                       Foreground="White" Opacity="0.9" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Theme toggle -->
                    <Button Style="{StaticResource MaterialDesignIconButton}"
                            Click="ThemeToggle_Click"
                            Width="36" Height="36" Margin="0,0,4,0"
                            ToolTip="Cambiar tema claro/oscuro"
                            AutomationProperties.Name="Cambiar tema claro/oscuro">
                        <materialDesign:PackIcon Kind="WeatherNight" Width="20" Height="20" Foreground="White"/>
                    </Button>
                </StackPanel>
            </DockPanel>
        </materialDesign:ColorZone>

        <!-- ══════════════════════ MAIN AREA ══════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="160" MaxWidth="300"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Welcome screen (no project) -->
            <views:WelcomeView Grid.Column="0" Grid.ColumnSpan="3"
                               DataContext="{Binding WelcomeVm}"
                               Visibility="{Binding DataContext.HasProyecto, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InvBoolToVis}}"/>

            <!-- ── SIDEBAR ── -->
            <Border Grid.Column="0"
                    BorderThickness="0,0,1,0"
                    BorderBrush="{DynamicResource MaterialDesign.Brush.DataGrid.ColumnHeader.Border}"
                    Visibility="{Binding HasProyecto, Converter={StaticResource BoolToVis}}">
                <StackPanel Margin="12">
                    <TextBlock Text="PROYECTO" Style="{StaticResource StatusBarText}"
                               FontWeight="SemiBold" Margin="4,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="8,6">
                        <materialDesign:PackIcon Kind="ClipboardTextOutline" Width="16" Height="16"
                                                  VerticalAlignment="Center" Margin="0,0,6,0"
                                                  Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"/>
                        <TextBlock Text="Todas las tareas" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Separator Margin="0,8"/>
                    <TextBlock Text="FASES" Style="{StaticResource StatusBarText}"
                               FontWeight="SemiBold" Margin="4,0,0,8"/>
                    <ItemsControl ItemsSource="{Binding Fases}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Nombre}" TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding Nombre}"
                                           Padding="8,8" FontSize="12"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Style="{StaticResource MaterialDesignFlatButton}"
                            Command="{Binding AddFaseCommand}"
                            HorizontalContentAlignment="Left" Padding="8,6"
                            Foreground="{DynamicResource MaterialDesign.Brush.Foreground}">
                        + Nueva fase
                    </Button>
                </StackPanel>
            </Border>

            <!-- ── PHASES + TASKS LIST ── -->
            <Grid Grid.Column="1"
                  Visibility="{Binding HasProyecto, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Project title bar (double-click to rename) -->
                <Border Grid.Row="0" Padding="16,10"
                        BorderThickness="0,0,0,1"
                        BorderBrush="{DynamicResource MaterialDesign.Brush.DataGrid.ColumnHeader.Border}">
                    <Grid>
                        <!-- Display mode -->
                        <StackPanel Orientation="Horizontal"
                                    Visibility="{Binding IsEditingProjectName, Converter={StaticResource InvBoolToVis}}">
                            <TextBlock Text="{Binding Proyecto.Nombre}"
                                       FontSize="18" FontWeight="SemiBold"
                                       VerticalAlignment="Center" Cursor="IBeam"
                                       ToolTip="Doble clic para renombrar">
                                <TextBlock.InputBindings>
                                    <MouseBinding MouseAction="LeftDoubleClick"
                                                  Command="{Binding BeginRenamingProjectCommand}"/>
                                </TextBlock.InputBindings>
                            </TextBlock>
                            <materialDesign:PackIcon Kind="PencilOutline" Width="16" Height="16"
                                                      VerticalAlignment="Center" Margin="8,0,0,0"
                                                      Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                                                      Opacity="0.45" ToolTip="Editar nombre" Cursor="Hand">
                                <materialDesign:PackIcon.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding BeginRenamingProjectCommand}"/>
                                </materialDesign:PackIcon.InputBindings>
                            </materialDesign:PackIcon>
                        </StackPanel>
                        <!-- Edit mode -->
                        <TextBox Text="{Binding Proyecto.Nombre, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 FontSize="18" FontWeight="SemiBold"
                                 Visibility="{Binding IsEditingProjectName, Converter={StaticResource BoolToVis}}"
                                 x:Name="ProjectNameBox"
                                 IsVisibleChanged="RenameBox_IsVisibleChanged"
                                 LostFocus="ProjectNameBox_LostFocus"
                                 KeyDown="ProjectNameBox_KeyDown"/>
                    </Grid>
                </Border>

                <!-- Empty phases hint -->
                <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding HasFases, Converter={StaticResource InvBoolToVis}}">
                    <materialDesign:PackIcon Kind="FolderOpenOutline" Width="48" Height="48"
                                               HorizontalAlignment="Center" Opacity="0.3" Margin="0,0,0,12"/>
                    <TextBlock Text="Sin fases todavía" Style="{StaticResource EmptyStateTitle}"/>
                    <TextBlock Text="Las fases organizan tu proyecto en etapas."
                               Style="{StaticResource EmptyStateDescription}"/>
                    <Button Style="{StaticResource MaterialDesignRaisedButton}"
                            Command="{Binding AddFaseCommand}"
                            Margin="0,16,0,0" HorizontalAlignment="Center">
                        + Crear primera fase
                    </Button>
                </StackPanel>

                <!-- Phases list -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              Focusable="False"
                              IsTabStop="False"
                              FocusVisualStyle="{x:Null}"
                              KeyboardNavigation.TabNavigation="None"
                              Visibility="{Binding HasFases, Converter={StaticResource BoolToVis}}">
                    <ItemsControl ItemsSource="{Binding Fases}"
                                  Focusable="False"
                                  IsTabStop="False"
                                  FocusVisualStyle="{x:Null}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:FaseViewModel}">
                                <StackPanel Margin="0,0,0,1">
                                    <DockPanel Margin="4,0">
                                        <Button DockPanel.Dock="Right"
                                                Style="{StaticResource MaterialDesignIconButton}"
                                                Command="{Binding DataContext.RemoveFaseCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Width="26" Height="26" Padding="3" Opacity="0.5"
                                                ToolTip="Eliminar fase"
                                                AutomationProperties.Name="Eliminar fase">
                                            <materialDesign:PackIcon Kind="Delete" Width="14" Height="14"/>
                                        </Button>
                                        <TextBlock Text="{Binding TaskCountLabel}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                                                   VerticalAlignment="Center"
                                                   DockPanel.Dock="Right" Margin="8,0"/>

                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <ToggleButton Style="{StaticResource MaterialDesignIconButton}"
                                                          Width="26" Height="26" Padding="3"
                                                          Margin="0,0,6,0"
                                                          IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                                          Focusable="False"
                                                          IsTabStop="False"
                                                          FocusVisualStyle="{x:Null}"
                                                          ToolTip="Expandir/contraer fase"
                                                          AutomationProperties.Name="Expandir o contraer fase">
                                                <Grid>
                                                    <materialDesign:PackIcon Kind="ChevronDown" Width="14" Height="14"
                                                                              Foreground="{DynamicResource ActionAccentBrush}"
                                                                              Visibility="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=ToggleButton}, Converter={StaticResource BoolToVis}}"/>
                                                    <materialDesign:PackIcon Kind="ChevronRight" Width="14" Height="14"
                                                                              Foreground="{DynamicResource ActionAccentBrush}"
                                                                              Visibility="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=ToggleButton}, Converter={StaticResource InvBoolToVis}}"/>
                                                </Grid>
                                            </ToggleButton>

                                            <StackPanel Orientation="Horizontal"
                                                        Visibility="{Binding IsEditingName, Converter={StaticResource InvBoolToVis}}">
                                                <TextBlock Text="{Binding Nombre}"
                                                           Style="{StaticResource PhaseHeaderText}"
                                                           Foreground="{DynamicResource ActionAccentBrush}"
                                                           ToolTip="Doble clic para renombrar"
                                                           Cursor="IBeam">
                                                    <TextBlock.InputBindings>
                                                        <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding BeginRenamingCommand}"/>
                                                    </TextBlock.InputBindings>
                                                </TextBlock>
                                                <materialDesign:PackIcon Kind="PencilOutline" Width="16" Height="16"
                                                                          Margin="6,-3,0,0"
                                                                          VerticalAlignment="Center"
                                                                          Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                                                                          Opacity="0.45"
                                                                          ToolTip="Editar nombre de fase"
                                                                          Cursor="Hand">
                                                    <materialDesign:PackIcon.InputBindings>
                                                        <MouseBinding MouseAction="LeftClick" Command="{Binding BeginRenamingCommand}"/>
                                                    </materialDesign:PackIcon.InputBindings>
                                                </materialDesign:PackIcon>
                                            </StackPanel>

                                            <TextBox Text="{Binding Nombre, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                     FontSize="14" FontWeight="SemiBold"
                                                     Visibility="{Binding IsEditingName, Converter={StaticResource BoolToVis}}"
                                                     x:Name="PhaseNameBox"
                                                     IsVisibleChanged="RenameBox_IsVisibleChanged"
                                                     LostFocus="PhaseNameBox_LostFocus"
                                                     KeyDown="PhaseNameBox_KeyDown"/>
                                        </StackPanel>
                                    </DockPanel>

                                    <!-- Task rows -->
                                    <StackPanel Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">
                                        <ItemsControl ItemsSource="{Binding Tareas}"
                                                      dd:DragDrop.IsDragSource="True"
                                                      dd:DragDrop.IsDropTarget="True"
                                                      dd:DragDrop.DropHandler="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:TareaViewModel}">
                                                    <Border x:Name="TaskRow"
                                                            Style="{StaticResource TaskRowBorder}">
                                                        <Border.InputBindings>
                                                            <MouseBinding MouseAction="LeftClick"
                                                                          Command="{Binding DataContext.SelectTareaCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                          CommandParameter="{Binding}"/>
                                                        </Border.InputBindings>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="28"/>
                                                                <ColumnDefinition Width="90"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="72"/>
                                                                <ColumnDefinition Width="130"/>
                                                                <ColumnDefinition Width="72"/>
                                                            </Grid.ColumnDefinitions>
                                                            <!-- Drag handle -->
                                                            <TextBlock Grid.Column="0" Text="⋮⋮"
                                                                       FontSize="14"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       Cursor="SizeAll"
                                                                       AutomationProperties.Name="Arrastrar tarea">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Opacity" Value="0"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                                                                                <Setter Property="Opacity" Value="0.5"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <!-- Status badge -->
                                                            <Border Grid.Column="1"
                                                                    Background="{Binding Estado, Converter={StaticResource EstadoColor}}"
                                                                    CornerRadius="10" Padding="6,2"
                                                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                                                    Margin="4,0">
                                                                <TextBlock Text="{Binding Estado}" FontSize="10" FontWeight="Medium"
                                                                           Foreground="White"/>
                                                            </Border>
                                                            <!-- Task name -->
                                                            <TextBlock Grid.Column="2" Text="{Binding Nombre}"
                                                                       Style="{StaticResource TaskRowName}"
                                                                       ToolTip="{Binding Nombre}"
                                                                       Margin="4,0"/>
                                                            <!-- Priority -->
                                                            <Border Grid.Column="3"
                                                                    CornerRadius="10" Padding="6,2"
                                                                    HorizontalAlignment="Left" VerticalAlignment="Center">
                                                                <TextBlock FontSize="10" FontWeight="Medium"
                                                                           Foreground="{Binding Prioridad, Converter={StaticResource PrioridadColor}}"
                                                                           Text="{Binding Prioridad}"/>
                                                            </Border>
                                                            <!-- Assignee initials -->
                                                            <StackPanel Grid.Column="4"
                                                                        Orientation="Horizontal"
                                                                        VerticalAlignment="Center"
                                                                        Margin="4,0">
                                                                <Border Style="{StaticResource AvatarCircle}"
                                                                        Background="#FF1F1F1F"
                                                                        BorderBrush="#66FFFFFF"
                                                                        BorderThickness="1">
                                                                    <TextBlock Text="{Binding Iniciales}"
                                                                               FontSize="9" FontWeight="Bold"
                                                                               Foreground="#FFFFFFFF"
                                                                               HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center"/>
                                                                </Border>
                                                                <TextBlock Text="{Binding Responsable, TargetNullValue=—}"
                                                                           Margin="6,0,0,0"
                                                                           VerticalAlignment="Center"
                                                                           FontSize="11"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"/>
                                                            </StackPanel>
                                                            <!-- Due date -->
                                                            <TextBlock Grid.Column="5"
                                                                       Text="{Binding FechaDisplay}"
                                                                       FontSize="11" VerticalAlignment="Center"
                                                                       HorizontalAlignment="Center">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding FechaVencida}" Value="True">
                                                                                <Setter Property="Foreground" Value="{StaticResource OverdueDateBrush}"/>
                                                                                <Setter Property="FontWeight" Value="Medium"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <!-- Add task row -->
                                        <Button Style="{StaticResource MaterialDesignFlatButton}"
                                                Command="{Binding DataContext.AddTareaToFaseCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                HorizontalAlignment="Left" Padding="28,4"
                                                Opacity="0.7" FontSize="12"
                                                Foreground="{DynamicResource ActionAccentBrush}">
                                            + Añadir tarea
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- ── TASK DETAIL PANEL ── -->
            <views:TaskDetailPanel Grid.Column="2"
                                   DataContext="{Binding SelectedTarea}"
                                   Visibility="{Binding DataContext.SelectedTarea, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource NotNullToVis}}"/>
        </Grid>

        <!-- ══════════════════════ STATUS BAR ══════════════════════ -->
        <StatusBar Grid.Row="2" Padding="8,4"
                   BorderThickness="0,1,0,0"
                   BorderBrush="{DynamicResource MaterialDesign.Brush.DataGrid.ColumnHeader.Border}">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Style="{StaticResource UnsavedDot}"
                             Visibility="{Binding IsDirty, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Style="{StaticResource StatusBarText}"
                               Visibility="{Binding IsDirty, Converter={StaticResource BoolToVis}}">
                        Cambios sin guardar
                    </TextBlock>
                    <TextBlock Style="{StaticResource StatusBarText}"
                               Visibility="{Binding IsDirty, Converter={StaticResource InvBoolToVis}}">
                        ✓ Guardado
                    </TextBlock>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Style="{StaticResource StatusBarText}"
                           Text="{Binding FileNameDisplay}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Style="{StaticResource StatusBarText}"
                           Text="{Binding TotalTareas, StringFormat='{}{0} tareas'}"
                           Visibility="{Binding HasProyecto, Converter={StaticResource BoolToVis}}"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Style="{StaticResource StatusBarText}" Text="MarkupPM v1.0"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
