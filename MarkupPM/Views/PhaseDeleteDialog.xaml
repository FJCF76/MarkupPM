<Window x:Class="MarkupPM.Views.PhaseDeleteDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Eliminar fase"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        MinWidth="460"
        Background="{DynamicResource SurfacePageBrush}"
        TextElement.Foreground="{DynamicResource TextPrimaryBrush}">
    <Border Padding="28,24,28,20"
            BorderThickness="0,3,0,0"
            BorderBrush="{DynamicResource DangerBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Border Width="32" Height="32" CornerRadius="16"
                        Background="{DynamicResource DangerLightBrush}"
                        Margin="0,0,12,0">
                    <materialDesign:PackIcon Kind="AlertOutline" Width="18" Height="18"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"
                                             Foreground="{DynamicResource DangerBrush}"/>
                </Border>
                <TextBlock x:Name="HeaderText" FontSize="15" FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
            </StackPanel>

            <TextBlock x:Name="MessageText"
                       Grid.Row="1"
                       Margin="44,0,0,0"
                       TextWrapping="Wrap"
                       FontSize="13"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,24,0,0">
                <Button x:Name="CancelButton"
                        Style="{StaticResource GhostButton}"
                        Padding="16,7"
                        Margin="0,0,8,0"
                        IsCancel="True"
                        Click="Cancel_Click">
                    Cancelar
                </Button>
                <Button x:Name="DeleteButton"
                        Style="{StaticResource DangerButton}"
                        Padding="16,7"
                        IsDefault="True"
                        Click="Delete_Click">
                    Eliminar
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>