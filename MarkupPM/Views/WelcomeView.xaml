<UserControl x:Class="MarkupPM.Views.WelcomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="400" Margin="40">

            <materialDesign:PackIcon Kind="ClipboardTextOutline" Width="52" Height="52"
                                       HorizontalAlignment="Center" Opacity="0.35" Margin="0,0,0,16"/>

            <TextBlock Text="Bienvenido a MarkupPM"
                       FontSize="22" FontWeight="SemiBold"
                       HorizontalAlignment="Center" Margin="0,0,0,8"/>

            <TextBlock Text="Gestiona tu proyecto como archivos Markdown.&#x0a;Sin servidor, sin nube — todo en tu máquina."
                       FontSize="13" HorizontalAlignment="Center" TextAlignment="Center"
                       Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                       TextWrapping="Wrap" Margin="0,0,0,24"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,32">
                <Button Style="{StaticResource MaterialDesignRaisedButton}"
                        Command="{Binding NuevoProyectoCommand}"
                        Margin="0,0,8,0" Padding="16,8">
                    + Crear proyecto nuevo
                </Button>
                <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                        Command="{Binding AbrirArchivoCommand}"
                        Padding="16,8">
                    📂 Abrir .md existente
                </Button>
            </StackPanel>

            <!-- Recent files -->
            <TextBlock Text="Recientes"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                       Margin="0,0,0,8"/>

            <ItemsControl ItemsSource="{Binding Recientes}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Style="{StaticResource MaterialDesignFlatButton}"
                                Command="{Binding DataContext.AbrirRecienteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"
                                HorizontalContentAlignment="Left"
                                Padding="8,6" Margin="0,2">
                            <TextBlock Text="{Binding}" FontSize="11"
                                       Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"/>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </Grid>
</UserControl>
