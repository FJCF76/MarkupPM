<UserControl x:Class="MarkupPM.Views.WelcomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:MarkupPM.Converters">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:BoolToVisibilityConverter x:Key="InvBoolToVis" Invert="True"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto" MinWidth="560" MaxWidth="820"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="1" Margin="40,48,40,40">

                <!-- ── Hero ── -->
                <Grid Margin="0,0,0,40">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <!-- Logo mark -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Border Width="36" Height="36"
                                    Background="{DynamicResource AccentBrush}"
                                    CornerRadius="9"
                                    Margin="0,0,12,0">
                                <TextBlock Text="MP" FontSize="13" FontWeight="Bold"
                                           Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="MarkupPM" FontSize="15" FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource AccentBrush}"/>
                        </StackPanel>

                        <TextBlock Style="{StaticResource DisplayText}"
                                   Text="¡Bienvenido! 👋"
                                   Margin="0,0,0,10"/>
                        <TextBlock FontSize="15"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,6">
                            Tu proyecto, en Markdown.
                        </TextBlock>
                        <TextBlock FontSize="12"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,28">
                            Gestiona proyectos como archivos <Run FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}">.md</Run>.
                            Sin servidor, sin nube — todo en tu máquina. Compatible con IA.
                        </TextBlock>

                        <!-- Primary actions -->
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource PrimaryButton}"
                                    Command="{Binding NuevoProyectoCommand}"
                                    Margin="0,0,10,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="PlusCircleOutline" Width="16" Height="16"
                                                              VerticalAlignment="Center" Margin="0,0,7,0"/>
                                    <TextBlock Text="Nuevo proyecto" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SecondaryButton}"
                                    Command="{Binding AbrirArchivoCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FolderOpenOutline" Width="16" Height="16"
                                                              VerticalAlignment="Center" Margin="0,0,7,0"/>
                                    <TextBlock Text="Abrir .md" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>

                    <!-- Decorative abstract shape (pure XAML, no images) -->
                    <Canvas Grid.Column="1" Width="120" Height="120" Margin="20,0,0,0"
                            VerticalAlignment="Center" Opacity="0.15">
                        <Ellipse Canvas.Left="10" Canvas.Top="10" Width="100" Height="100"
                                 Fill="{DynamicResource AccentBrush}"/>
                        <Ellipse Canvas.Left="40" Canvas.Top="0" Width="60" Height="60"
                                 Fill="{DynamicResource AccentBrush}" Opacity="0.6"/>
                        <Ellipse Canvas.Left="60" Canvas.Top="50" Width="50" Height="50"
                                 Fill="{DynamicResource AccentDarkBrush}" Opacity="0.5"/>
                    </Canvas>
                </Grid>

                <!-- ── Recent projects ── -->
                <StackPanel>
                    <DockPanel Margin="0,0,0,14">
                        <TextBlock Text="Recientes" Style="{StaticResource TitleText}" FontSize="14"/>
                    </DockPanel>

                    <!-- Empty recents state -->
                    <Border Style="{StaticResource CardBorder}"
                            Visibility="{Binding HasRecientes, Converter={StaticResource InvBoolToVis}}">
                        <StackPanel HorizontalAlignment="Center" Margin="0,20">
                            <materialDesign:PackIcon Kind="ClipboardTextOutline" Width="40" Height="40"
                                                      HorizontalAlignment="Center" Opacity="0.2" Margin="0,0,0,10"/>
                            <TextBlock Text="Sin proyectos recientes"
                                       Style="{StaticResource EmptyStateTitle}"
                                       FontSize="13"/>
                            <TextBlock Text="Crea o abre un proyecto .md para empezar."
                                       Style="{StaticResource EmptyStateDescription}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Recent files list -->
                    <ItemsControl ItemsSource="{Binding Recientes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,6"
                                        Background="{DynamicResource SurfaceCardBrush}"
                                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Cursor="Hand"
                                        Padding="14,11">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding DataContext.AbrirRecienteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding}"/>
                                    </Border.InputBindings>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Background" Value="{DynamicResource SurfaceSelectedBrush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <DockPanel>
                                        <materialDesign:PackIcon Kind="FileDocumentOutline" Width="16" Height="16"
                                                                  VerticalAlignment="Center"
                                                                  Foreground="{DynamicResource AccentBrush}"
                                                                  Margin="0,0,10,0"
                                                                  DockPanel.Dock="Left"/>
                                        <materialDesign:PackIcon Kind="ChevronRight" Width="14" Height="14"
                                                                  VerticalAlignment="Center"
                                                                  Foreground="{DynamicResource TextMutedBrush}"
                                                                  DockPanel.Dock="Right"/>
                                        <TextBlock Text="{Binding}" FontSize="12"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   ToolTip="{Binding}"/>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>


            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
