<Window x:Class="MarkupPM.Views.SaveFileDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Guardar proyecto"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SizeToContent="Height"
        Width="480"
        Background="{DynamicResource SurfacePageBrush}"
        TextElement.Foreground="{DynamicResource TextPrimaryBrush}">
    <Border Padding="24,20,24,20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Guardar proyecto"
                       FontSize="15" FontWeight="SemiBold"
                       Margin="0,0,0,16"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>

            <StackPanel Grid.Row="1" Margin="0,0,0,12">
                <TextBlock Text="Nombre del archivo"
                           FontSize="12"
                           Margin="0,0,0,6"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBox x:Name="FileNameBox"
                         FontSize="13"
                         Padding="8,7"
                         Background="{DynamicResource SurfaceCardBrush}"
                         BorderBrush="{DynamicResource DividerBrush}"
                         TextChanged="FileNameBox_TextChanged"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Margin="0,0,0,4">
                <TextBlock Text="Ubicación"
                           FontSize="12"
                           Margin="0,0,0,6"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock x:Name="LocationText"
                           FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,20,0,0">
                <Button Content="Cancelar"
                        IsCancel="True"
                        Padding="16,7"
                        Margin="0,0,8,0"
                        Click="CancelBtn_Click"/>
                <Button x:Name="SaveBtn"
                        Content="Guardar"
                        IsDefault="True"
                        IsEnabled="False"
                        Padding="16,7"
                        Click="SaveBtn_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
