<UserControl x:Class="MarkupPM.Views.TaskDetailPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:MarkupPM.Converters"
             xmlns:models="clr-namespace:MarkupPM.Models"
             Width="300">
    <UserControl.Resources>
        <converters:EstadoToColorConverter x:Key="EstadoColor"/>
        <converters:PrioridadToColorConverter x:Key="PrioridadColor"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Border BorderThickness="1,0,0,0"
            BorderBrush="{DynamicResource BorderSubtleBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Panel header -->
            <Border Grid.Row="0" Padding="16,10"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                    Background="{DynamicResource SurfacePageBrush}">
                <DockPanel>
                    <Button DockPanel.Dock="Right"
                            Style="{StaticResource MaterialDesignIconButton}"
                            Command="{Binding DataContext.ClosePanelCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            Width="28" Height="28" Padding="4"
                            VerticalAlignment="Center"
                            ToolTip="Cerrar panel (Esc)">
                        <materialDesign:PackIcon Kind="Close" Width="15" Height="15"
                                                  Foreground="{DynamicResource TextMutedBrush}"/>
                    </Button>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="ClipboardTextOutline"
                                                  Width="15" Height="15"
                                                  Foreground="{DynamicResource AccentBrush}"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,7,0"/>
                        <TextBlock Text="Detalle de tarea"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Scrollable fields -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          Padding="0,0,2,0">
                <StackPanel Margin="16,18,16,12">

                    <!-- Task name -->
                    <TextBox Text="{Binding Nombre, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource DetailTextBox}"
                             materialDesign:HintAssist.Hint="Nombre de la tarea"
                             FontSize="14" FontWeight="Medium"
                             TextAlignment="Left"
                             TextWrapping="Wrap" AcceptsReturn="False"
                             Margin="0,0,0,18"/>

                    <!-- Estado + Prioridad -->
                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Estado" Style="{StaticResource DetailFieldLabel}"/>
                            <ComboBox ItemsSource="{Binding Source={x:Static models:EstadoTareaValues.All}}"
                                      SelectedItem="{Binding Estado}"
                                      Style="{StaticResource DetailComboBox}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Prioridad" Style="{StaticResource DetailFieldLabel}"/>
                            <ComboBox ItemsSource="{Binding Source={x:Static models:PrioridadTareaValues.All}}"
                                      SelectedItem="{Binding Prioridad}"
                                      Style="{StaticResource DetailComboBox}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Responsable + Fecha -->
                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Responsable" Style="{StaticResource DetailFieldLabel}"/>
                            <TextBox Text="{Binding Responsable, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource DetailTextBox}"
                                     materialDesign:HintAssist.Hint="—"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Fecha límite" Style="{StaticResource DetailFieldLabel}"/>
                            <DatePicker SelectedDate="{Binding FechaAsDateTime}"
                                        Style="{StaticResource DetailDatePicker}"
                                        materialDesign:HintAssist.Hint="—"/>
                        </StackPanel>
                    </Grid>

                    <!-- Divider -->
                    <Border Height="1" Background="{DynamicResource BorderSubtleBrush}"
                            Margin="0,0,0,16" Opacity="0.6"/>

                    <!-- Notas -->
                    <StackPanel>
                        <TextBlock Text="Notas" Style="{StaticResource DetailFieldLabel}"/>
                        <TextBox Text="{Binding Notas, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DetailTextBox}"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 TextAlignment="Left"
                                 MinHeight="100"
                                 VerticalScrollBarVisibility="Auto"
                                 materialDesign:HintAssist.Hint="Notas sobre esta tarea..."/>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer: delete -->
            <Border Grid.Row="2" Padding="12,8"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                    Background="{DynamicResource SurfacePageBrush}">
                <Button Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="{DynamicResource DangerBrush}"
                        Opacity="0.85"
                        Command="{Binding DataContext.DeleteSelectedTareaCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        HorizontalAlignment="Left" Padding="4,6">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="DeleteOutline" Width="16" Height="16"
                                                  VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Eliminar tarea" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Border>
        </Grid>
    </Border>
</UserControl>
